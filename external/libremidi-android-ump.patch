+#pragma once
+#include <libremidi/backends/android_ump/midi_in.hpp>
+#include <libremidi/backends/android_ump/midi_out.hpp>
+#include <libremidi/backends/android_ump/observer.hpp>
+
+#include <string_view>
+
+NAMESPACE_LIBREMIDI
+{
+namespace android_ump
+{
+struct backend
+{
+  using midi_in = android_ump::midi_in;
+  using midi_out = android_ump::midi_out;
+  using midi_observer = android_ump::observer;
+  using midi_in_configuration = android_ump::input_configuration;
+  using midi_out_configuration = android_ump::output_configuration;
+  using midi_observer_configuration = android_ump::observer_configuration;
+
+  static const constexpr auto API = libremidi::API::ANDROID_AMIDI_UMP;
+  static const constexpr std::string_view name = "android_ump";
+  static const constexpr std::string_view display_name = "Android MIDI 2.0 API";
+
+  static bool available() noexcept
+  {
+#if defined(LIBREMIDI_ANDROID_UMP)
+    return true;
+#else
+    return false;
+#endif
+  }
+};
+}
