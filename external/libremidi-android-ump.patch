diff --git a/include/libremidi/backends/android_ump/helpers.cpp b/include/libremidi/backends/android_ump/helpers.cpp
new file mode 100644
index 0000000..bd837cc
--- /dev/null
+++ b/include/libremidi/backends/android_ump/helpers.cpp
@@ -0,0 +1,221 @@
+#include <libremidi/backends/android_ump/helpers.hpp>
+#include <libremidi/backends/android_ump/midi_in.hpp>
+#include <libremidi/backends/android_ump/midi_out.hpp>
+
+NAMESPACE_LIBREMIDI::android_ump
+{
+
+void context::refresh_midi_devices(JNIEnv* env, jobject ctx, bool is_output)
+{
+  cleanup_devices(env);
+
+  auto midi_service = get_midi_manager(env, ctx);
+  if (!midi_service)
+    return;
+
+  auto midi_mgr_class = env->FindClass("android/media/midi/MidiManager");
+  auto get_devices_method = env->GetMethodID(
+      midi_mgr_class, "getDevicesForTransport", "(I)Ljava/util/Set;");
+  auto device_collection
+      = env->CallObjectMethod(midi_service, get_devices_method, TRANSPORT_UMP);
+
+  if (!device_collection)
+  {
+    env->DeleteLocalRef(midi_service);
+    return;
+  }
+
+  auto set_class = env->FindClass("java/util/Set");
+  auto to_array_method
+      = env->GetMethodID(set_class, "toArray", "()[Ljava/lang/Object;");
+  auto device_array = (jobjectArray)env->CallObjectMethod(device_collection, to_array_method);
+
+  auto device_info_class = env->FindClass("android/media/midi/MidiDeviceInfo");
+  auto get_props_method
+      = env->GetMethodID(device_info_class, "getProperties", "()Landroid/os/Bundle;");
+  auto get_ports_method = env->GetMethodID(
+      device_info_class, "getPorts",
+      "()[Landroid/media/midi/MidiDeviceInfo$PortInfo;");
+
+  auto bundle_class = env->FindClass("android/os/Bundle");
+  auto get_string_method
+      = env->GetMethodID(bundle_class, "getString", "(Ljava/lang/String;)Ljava/lang/String;");
+
+  auto port_info_class = env->FindClass("android/media/midi/MidiDeviceInfo$PortInfo");
+  auto get_name_method = env->GetMethodID(port_info_class, "getName", "()Ljava/lang/String;");
+  auto get_type_method = env->GetMethodID(port_info_class, "getType", "()I");
+  auto get_port_number_method = env->GetMethodID(port_info_class, "getPortNumber", "()I");
+
+  // TYPE_INPUT=1 (app sends to device), TYPE_OUTPUT=2 (app receives from device)
+  jint wanted_type = is_output ? 1 : 2;
+
+  jsize count = env->GetArrayLength(device_array);
+  for (jsize i = 0; i < count; ++i)
+  {
+    auto device_info = env->GetObjectArrayElement(device_array, i);
+
+    // Device name: MidiDeviceInfo.PROPERTY_NAME = "name"
+    auto bundle = env->CallObjectMethod(device_info, get_props_method);
+    auto name_key = env->NewStringUTF("name");
+    auto device_name_jstr = (jstring)env->CallObjectMethod(bundle, get_string_method, name_key);
+    std::string device_name;
+    if (device_name_jstr)
+    {
+      const char* chars = env->GetStringUTFChars(device_name_jstr, nullptr);
+      device_name = chars;
+      env->ReleaseStringUTFChars(device_name_jstr, chars);
+      env->DeleteLocalRef(device_name_jstr);
+    }
+    env->DeleteLocalRef(name_key);
+    env->DeleteLocalRef(bundle);
+
+    auto ports_array
+        = (jobjectArray)env->CallObjectMethod(device_info, get_ports_method);
+    jsize port_count = env->GetArrayLength(ports_array);
+
+    for (jsize p = 0; p < port_count; ++p)
+    {
+      auto port_info = env->GetObjectArrayElement(ports_array, p);
+      jint port_type = env->CallIntMethod(port_info, get_type_method);
+
+      if (port_type == wanted_type)
+      {
+        jint port_number = env->CallIntMethod(port_info, get_port_number_method);
+        auto port_name_jstr = (jstring)env->CallObjectMethod(port_info, get_name_method);
+
+        std::string port_name;
+        if (port_name_jstr)
+        {
+          const char* chars = env->GetStringUTFChars(port_name_jstr, nullptr);
+          port_name = chars;
+          env->ReleaseStringUTFChars(port_name_jstr, chars);
+          env->DeleteLocalRef(port_name_jstr);
+        }
+
+        // Mirror KtMidi AndroidPortDetails.name: only append port name if it's
+        // not the generic "input"/"output" placeholder.
+        std::string display_name = device_name;
+        if (!port_name.empty() && port_name != "input" && port_name != "output")
+          display_name += ": " + port_name;
+
+        midi_devices.push_back(env->NewGlobalRef(device_info));
+        midi_port_indices.push_back((int)port_number);
+        midi_port_names.push_back(std::move(display_name));
+      }
+      env->DeleteLocalRef(port_info);
+    }
+    env->DeleteLocalRef(ports_array);
+    env->DeleteLocalRef(device_info);
+  }
+
+  env->DeleteLocalRef(device_array);
+  env->DeleteLocalRef(device_collection);
+  env->DeleteLocalRef(midi_service);
+}
+
+std::string context::port_name(JNIEnv* /*env*/, unsigned int port_number)
+{
+  if (port_number >= midi_port_names.size())
+  {
+    LOGE("Invalid port number");
+    return "";
+  }
+  return midi_port_names[port_number];
+}
+
+void context::cleanup_devices(JNIEnv* env)
+{
+  for (jobject device : midi_devices)
+    env->DeleteGlobalRef(device);
+  midi_devices.clear();
+  midi_port_indices.clear();
+  midi_port_names.clear();
+}
+
+void context::open_device(jobject device_info, void* target, bool is_output)
+{
+  auto env = get_thread_env();
+  if (!env)
+    return;
+
+  auto ctx = get_context(env);
+  if (!ctx)
+    return;
+
+  auto midi_mgr = get_midi_manager(env, ctx);
+  if (!midi_mgr)
+    return;
+
+  auto looper_class = env->FindClass("android/os/Looper");
+  auto get_my_looper_method
+      = env->GetStaticMethodID(looper_class, "myLooper", "()Landroid/os/Looper;");
+  auto my_looper = env->CallStaticObjectMethod(looper_class, get_my_looper_method);
+
+  jobject handler = nullptr;
+  if (!my_looper)
+  {
+    LOGI("Not on a Looper thread, using main looper");
+    auto get_main_looper_method
+        = env->GetStaticMethodID(looper_class, "getMainLooper", "()Landroid/os/Looper;");
+    auto main_looper = env->CallStaticObjectMethod(looper_class, get_main_looper_method);
+
+    auto handler_class = env->FindClass("android/os/Handler");
+    auto handler_ctor = env->GetMethodID(handler_class, "<init>", "(Landroid/os/Looper;)V");
+    handler = env->NewObject(handler_class, handler_ctor, main_looper);
+
+    env->DeleteLocalRef(main_looper);
+  }
+
+  auto callback_class = env->FindClass("dev/celtera/libremidi/MidiDeviceCallbackUmp");
+  if (!callback_class)
+  {
+    LOGE("MidiDeviceCallbackUmp class not found - ensure the Java class is loaded");
+    if (handler)
+      env->DeleteLocalRef(handler);
+    return;
+  }
+
+  auto callback_ctor = env->GetMethodID(callback_class, "<init>", "(JZ)V");
+  auto callback
+      = env->NewObject(callback_class, callback_ctor, (jlong)target, (jboolean)is_output);
+
+  auto midi_mgr_class = env->FindClass("android/media/midi/MidiManager");
+  auto open_device_method = env->GetMethodID(
+      midi_mgr_class, "openDevice",
+      "(Landroid/media/midi/MidiDeviceInfo;Landroid/media/midi/"
+      "MidiManager$OnDeviceOpenedListener;Landroid/os/Handler;)V");
+
+  env->CallVoidMethod(midi_mgr, open_device_method, device_info, callback, handler);
+
+  env->DeleteLocalRef(callback);
+  if (handler)
+    env->DeleteLocalRef(handler);
+}
+
+extern "C" JNIEXPORT void JNICALL
+Java_dev_celtera_libremidi_MidiDeviceCallbackUmp_onDeviceOpened(
+    JNIEnv* env, jobject /*thiz*/, jobject midi_device, jlong target_ptr, jboolean is_output)
+{
+  if (!midi_device || target_ptr == 0)
+  {
+    LOGE("Invalid device or target pointer in UMP callback");
+    return;
+  }
+
+  if (is_output)
+    midi_out::open_callback(reinterpret_cast<midi_out*>(target_ptr), env, midi_device);
+  else
+    midi_in::open_callback(reinterpret_cast<midi_in*>(target_ptr), env, midi_device);
+}
+
+extern "C" JNIEXPORT void JNICALL
+Java_dev_celtera_libremidi_MidiUmpReceiver_onUmpData(
+    JNIEnv* env, jobject /*thiz*/, jlong ptr, jbyteArray msg, jint offset, jint count,
+    jlong timestamp)
+{
+  if (ptr == 0)
+    return;
+  midi_in::on_ump_data(reinterpret_cast<midi_in*>(ptr), env, msg, offset, count, timestamp);
+}
+
+}
diff --git a/include/libremidi/backends/android_ump/helpers.hpp b/include/libremidi/backends/android_ump/helpers.hpp
new file mode 100644
index 0000000..0815034
--- /dev/null
+++ b/include/libremidi/backends/android_ump/helpers.hpp
@@ -0,0 +1,35 @@
+#pragma once
+#include <libremidi/backends/android/helpers.hpp>
+
+NAMESPACE_LIBREMIDI
+{
+namespace android_ump
+{
+// TRANSPORT_UNIVERSAL_MIDI_PACKETS = 2 (requires API 33+)
+static constexpr jint TRANSPORT_UMP = 2;
+
+struct context
+{
+  static inline std::string client_name;
+  static inline std::vector<jobject> midi_devices;
+  static inline std::vector<int> midi_port_indices;
+  static inline std::vector<std::string> midi_port_names;
+
+  static JNIEnv* get_thread_env() { return android::context::get_thread_env(); }
+  static jobject get_context(JNIEnv* env) { return android::context::get_context(env); }
+  static jobject get_midi_manager(JNIEnv* env, jobject ctx)
+  {
+    return android::context::get_midi_manager(env, ctx);
+  }
+
+  static void refresh_midi_devices(JNIEnv* env, jobject ctx, bool is_output);
+  static void open_device(jobject device_info, void* target, bool is_output);
+  static std::string port_name(JNIEnv* env, unsigned int port_number);
+  static void cleanup_devices(JNIEnv* env);
+};
+
+extern "C" JNIEXPORT void JNICALL
+Java_dev_celtera_libremidi_MidiDeviceCallbackUmp_onDeviceOpened(
+    JNIEnv* env, jobject /*thiz*/, jobject midi_device, jlong target_ptr, jboolean is_output);
+}
+}
diff --git a/include/libremidi/backends/android_ump/midi_in.hpp b/include/libremidi/backends/android_ump/midi_in.hpp
new file mode 100644
index 0000000..a359c29
--- /dev/null
+++ b/include/libremidi/backends/android_ump/midi_in.hpp
@@ -0,0 +1,190 @@
+#pragma once
+#include <libremidi/backends/android_ump/config.hpp>
+#include <libremidi/backends/android_ump/helpers.hpp>
+#include <libremidi/detail/midi_in.hpp>
+#include <libremidi/detail/midi_stream_decoder.hpp>
+
+NAMESPACE_LIBREMIDI
+{
+namespace android_ump
+{
+class midi_in
+    : public midi2::in_api
+    , public error_handler
+{
+public:
+  struct
+      : libremidi::ump_input_configuration
+      , android_ump::input_configuration
+  {
+  } configuration;
+
+  explicit midi_in(
+      libremidi::ump_input_configuration&& conf, android_ump::input_configuration aconf)
+      : configuration{std::move(conf), std::move(aconf)}
+  {
+    if (!context::client_name.empty()
+        && context::client_name != configuration.client_name)
+    {
+      libremidi_handle_error(
+          this->configuration, "Android backend only supports one client name per process");
+      return;
+    }
+    context::client_name = std::string(configuration.client_name);
+    client_open_ = stdx::error{};
+  }
+
+  ~midi_in() override { close_port(); }
+
+  libremidi::API get_current_api() const noexcept override
+  {
+    return libremidi::API::ANDROID_AMIDI_UMP;
+  }
+
+  stdx::error open_port(const input_port& port, std::string_view /*name*/) override
+  {
+    if (is_port_open())
+    {
+      libremidi_handle_error(configuration, "midi_in::open_port: a port is already open");
+      return std::errc{};
+    }
+
+    const unsigned int port_number = port.port;
+    auto env = context::get_thread_env();
+    if (!env)
+    {
+      libremidi_handle_error(configuration, "midi_in::open_port: failed to get JNI environment");
+      return std::errc{};
+    }
+
+    auto ctx = context::get_context(env);
+    if (!ctx)
+    {
+      libremidi_handle_error(configuration, "midi_in::open_port: failed to get Android context");
+      return std::errc{};
+    }
+
+    context::refresh_midi_devices(env, ctx, false);
+
+    if (port_number >= context::midi_devices.size())
+    {
+      libremidi_handle_error(configuration, "midi_in::open_port: invalid port number");
+      return std::errc{};
+    }
+
+    port_open = true;
+    amidi_port_index = context::midi_port_indices[port_number];
+    context::open_device(context::midi_devices[port_number], this, false);
+    return stdx::error{};
+  }
+
+  stdx::error close_port() override
+  {
+    if (!is_port_open())
+      return std::errc{};
+
+    port_open = false;
+
+    auto env = context::get_thread_env();
+    if (java_receiver && env)
+    {
+      auto receiver_class = env->GetObjectClass(java_receiver);
+      auto deactivate = env->GetMethodID(receiver_class, "deactivate", "()V");
+      env->CallVoidMethod(java_receiver, deactivate);
+      env->DeleteGlobalRef(java_receiver);
+      java_receiver = nullptr;
+    }
+    if (java_output_port && env)
+    {
+      auto port_class = env->GetObjectClass(java_output_port);
+      auto close_method = env->GetMethodID(port_class, "close", "()V");
+      env->CallVoidMethod(java_output_port, close_method);
+      env->ExceptionClear();
+      env->DeleteGlobalRef(java_output_port);
+      java_output_port = nullptr;
+    }
+
+    return stdx::error{};
+  }
+
+  bool is_port_open() const noexcept { return port_open; }
+
+  timestamp absolute_timestamp() const noexcept override { return system_ns(); }
+
+  static void open_callback(midi_in* self, JNIEnv* env, jobject midi_device)
+  {
+    if (!self->port_open)
+      return;
+
+    auto device_class = env->GetObjectClass(midi_device);
+    auto open_output_port_method = env->GetMethodID(
+        device_class, "openOutputPort", "(I)Landroid/media/midi/MidiOutputPort;");
+    auto java_port
+        = env->CallObjectMethod(midi_device, open_output_port_method, self->amidi_port_index);
+    if (env->ExceptionCheck())
+      env->ExceptionClear();
+
+    if (!java_port)
+    {
+      LOGE("Failed to open Java MidiOutputPort for UMP input");
+      self->port_open = false;
+      return;
+    }
+
+    auto receiver_class = env->FindClass("dev/celtera/libremidi/MidiUmpReceiver");
+    if (!receiver_class)
+    {
+      LOGE("MidiUmpReceiver class not found");
+      env->DeleteLocalRef(java_port);
+      self->port_open = false;
+      return;
+    }
+    auto receiver_ctor = env->GetMethodID(receiver_class, "<init>", "(J)V");
+    auto receiver = env->NewObject(receiver_class, receiver_ctor, (jlong)self);
+
+    auto output_port_class = env->GetObjectClass(java_port);
+    auto connect_method = env->GetMethodID(
+        output_port_class, "connect", "(Landroid/media/midi/MidiReceiver;)V");
+    env->CallVoidMethod(java_port, connect_method, receiver);
+    if (env->ExceptionCheck())
+      env->ExceptionClear();
+
+    self->java_output_port = env->NewGlobalRef(java_port);
+    self->java_receiver = env->NewGlobalRef(receiver);
+    env->DeleteLocalRef(java_port);
+    env->DeleteLocalRef(receiver);
+  }
+
+  static void on_ump_data(
+      midi_in* self, JNIEnv* env, jbyteArray msg, jint offset, jint count, jlong timestamp)
+  {
+    if (!self->port_open || count <= 0 || (count % (jint)sizeof(uint32_t)) != 0)
+      return;
+
+    static constexpr timestamp_backend_info timestamp_info{
+        .has_absolute_timestamps = true,
+        .absolute_is_monotonic = true,
+        .has_samples = false,
+    };
+
+    jbyte* bytes = env->GetByteArrayElements(msg, nullptr);
+    const uint32_t* words = reinterpret_cast<const uint32_t*>(bytes + offset);
+    size_t num_words = (size_t)count / sizeof(uint32_t);
+
+    const auto to_ns = [=] { return (int64_t)timestamp; };
+    self->m_processing.on_bytes_multi(
+        {words, words + num_words},
+        self->m_processing.timestamp<timestamp_info>(to_ns, timestamp));
+
+    env->ReleaseByteArrayElements(msg, bytes, JNI_ABORT);
+  }
+
+private:
+  jobject java_output_port{};
+  jobject java_receiver{};
+  bool port_open{false};
+  int amidi_port_index{0};
+  midi2::input_state_machine m_processing{this->configuration};
+};
+}
+}
diff --git a/include/libremidi/backends/android_ump/midi_out.hpp b/include/libremidi/backends/android_ump/midi_out.hpp
new file mode 100644
index 0000000..6541c7a
--- /dev/null
+++ b/include/libremidi/backends/android_ump/midi_out.hpp
@@ -0,0 +1,160 @@
+#pragma once
+#include <libremidi/backends/android_ump/config.hpp>
+#include <libremidi/backends/android_ump/helpers.hpp>
+#include <libremidi/detail/midi_out.hpp>
+
+NAMESPACE_LIBREMIDI
+{
+namespace android_ump
+{
+class midi_out final
+    : public midi2::out_api
+    , public error_handler
+{
+public:
+  struct
+      : libremidi::output_configuration
+      , android_ump::output_configuration
+  {
+  } configuration;
+
+  explicit midi_out(
+      libremidi::output_configuration&& conf, android_ump::output_configuration aconf)
+      : configuration{std::move(conf), std::move(aconf)}
+  {
+    if (!context::client_name.empty()
+        && context::client_name != configuration.client_name)
+    {
+      libremidi_handle_error(
+          this->configuration, "Android backend only supports one client name per process");
+      return;
+    }
+    context::client_name = std::string(configuration.client_name);
+    client_open_ = stdx::error{};
+  }
+
+  ~midi_out() override { close_port(); }
+
+  libremidi::API get_current_api() const noexcept override
+  {
+    return libremidi::API::ANDROID_AMIDI_UMP;
+  }
+
+  stdx::error open_port(const output_port& port, std::string_view /*name*/) override
+  {
+    if (is_port_open())
+    {
+      libremidi_handle_error(configuration, "midi_out::open_port: a port is already open");
+      return std::errc{};
+    }
+
+    const unsigned int port_number = port.port;
+    auto env = context::get_thread_env();
+    if (!env)
+    {
+      libremidi_handle_error(configuration, "midi_out::open_port: failed to get JNI environment");
+      return std::errc{};
+    }
+
+    auto ctx = context::get_context(env);
+    if (!ctx)
+    {
+      libremidi_handle_error(configuration, "midi_out::open_port: failed to get Android context");
+      return std::errc{};
+    }
+
+    context::refresh_midi_devices(env, ctx, true);
+
+    if (port_number >= context::midi_devices.size())
+    {
+      libremidi_handle_error(configuration, "midi_out::open_port: invalid port number");
+      return std::errc{};
+    }
+
+    port_open = true;
+    amidi_port_index = context::midi_port_indices[port_number];
+    context::open_device(context::midi_devices[port_number], this, true);
+    return stdx::error{};
+  }
+
+  stdx::error close_port() override
+  {
+    if (!is_port_open())
+      return std::errc{};
+
+    port_open = false;
+
+    auto env = context::get_thread_env();
+    if (java_input_port && env)
+    {
+      auto port_class = env->GetObjectClass(java_input_port);
+      auto close_method = env->GetMethodID(port_class, "close", "()V");
+      env->CallVoidMethod(java_input_port, close_method);
+      env->ExceptionClear();
+      env->DeleteGlobalRef(java_input_port);
+      java_input_port = nullptr;
+    }
+
+    return stdx::error{};
+  }
+
+  bool is_port_open() const noexcept { return port_open; }
+
+  stdx::error send_ump(const uint32_t* ump_stream, std::size_t count) override
+  {
+    if (!is_port_open() || !java_input_port)
+    {
+      libremidi_handle_error(configuration, "midi_out::send_ump: port is not open");
+      return std::errc{};
+    }
+
+    auto env = context::get_thread_env();
+    if (!env)
+      return std::errc{};
+
+    jint byte_count = (jint)(count * sizeof(uint32_t));
+    auto byte_array = env->NewByteArray(byte_count);
+    env->SetByteArrayRegion(
+        byte_array, 0, byte_count, reinterpret_cast<const jbyte*>(ump_stream));
+
+    auto port_class = env->GetObjectClass(java_input_port);
+    auto send_method = env->GetMethodID(port_class, "send", "([BIIJ)V");
+    env->CallVoidMethod(java_input_port, send_method, byte_array, 0, byte_count, (jlong)0);
+    if (env->ExceptionCheck())
+      env->ExceptionClear();
+
+    env->DeleteLocalRef(byte_array);
+    return stdx::error{};
+  }
+
+  static void open_callback(midi_out* self, JNIEnv* env, jobject midi_device)
+  {
+    if (!self->port_open)
+      return;
+
+    auto device_class = env->GetObjectClass(midi_device);
+    auto open_input_port_method = env->GetMethodID(
+        device_class, "openInputPort", "(I)Landroid/media/midi/MidiInputPort;");
+    auto java_port
+        = env->CallObjectMethod(midi_device, open_input_port_method, self->amidi_port_index);
+    if (env->ExceptionCheck())
+      env->ExceptionClear();
+
+    if (!java_port)
+    {
+      LOGE("Failed to open Java MidiInputPort for UMP output");
+      self->port_open = false;
+      return;
+    }
+
+    self->java_input_port = env->NewGlobalRef(java_port);
+    env->DeleteLocalRef(java_port);
+  }
+
+private:
+  jobject java_input_port{};
+  bool port_open{false};
+  int amidi_port_index{0};
+};
+}
+}
diff --git a/include/libremidi/backends/android_ump/observer.hpp b/include/libremidi/backends/android_ump/observer.hpp
new file mode 100644
index 0000000..11827b8
--- /dev/null
+++ b/include/libremidi/backends/android_ump/observer.hpp
@@ -0,0 +1,92 @@
+#pragma once
+#include <libremidi/backends/android_ump/config.hpp>
+#include <libremidi/backends/android_ump/helpers.hpp>
+#include <libremidi/detail/observer.hpp>
+
+NAMESPACE_LIBREMIDI
+{
+namespace android_ump
+{
+class observer final
+    : public libremidi::observer_api
+    , public error_handler
+{
+public:
+  explicit observer(
+      libremidi::observer_configuration&& conf, android_ump::observer_configuration aconf)
+      : configuration{std::move(conf)}
+  {
+    if (!context::client_name.empty() && context::client_name != aconf.client_name)
+    {
+      LOGW("Android backend only supports one client name per process");
+    }
+    context::client_name = std::string(aconf.client_name);
+  }
+
+  ~observer()
+  {
+    auto env = context::get_thread_env();
+    if (env)
+      context::cleanup_devices(env);
+  }
+
+  libremidi::API get_current_api() const noexcept override
+  {
+    return libremidi::API::ANDROID_AMIDI_UMP;
+  }
+
+  std::vector<libremidi::input_port> get_input_ports() const noexcept override
+  {
+    auto env = context::get_thread_env();
+    if (!env)
+      return {};
+
+    auto ctx = context::get_context(env);
+    if (!ctx)
+      return {};
+
+    context::refresh_midi_devices(env, ctx, false);
+
+    std::vector<libremidi::input_port> ports;
+    for (size_t i = 0; i < context::midi_devices.size(); ++i)
+    {
+      libremidi::input_port port;
+      port.api = libremidi::API::ANDROID_AMIDI_UMP;
+      port.port_name = context::port_name(env, i);
+      port.port = i;
+      ports.push_back(std::move(port));
+    }
+
+    return ports;
+  }
+
+  std::vector<libremidi::output_port> get_output_ports() const noexcept override
+  {
+    auto env = context::get_thread_env();
+    if (!env)
+      return {};
+
+    auto ctx = context::get_context(env);
+    if (!ctx)
+      return {};
+
+    context::refresh_midi_devices(env, ctx, true);
+
+    std::vector<libremidi::output_port> ports;
+    for (size_t i = 0; i < context::midi_devices.size(); ++i)
+    {
+      libremidi::output_port port;
+      port.api = libremidi::API::ANDROID_AMIDI_UMP;
+      port.port_name = context::port_name(env, i);
+      port.port = i;
+      ports.push_back(std::move(port));
+    }
+
+    return ports;
+  }
+
+private:
+  libremidi::observer_configuration configuration;
+};
+}
+}
